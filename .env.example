# LangFuse API keys — get these from http://localhost:3001 after first login
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Ollama (running on host machine, not in Docker)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_PRIMARY_MODEL=qwen2.5-coder:7b
OLLAMA_SYNTHESIS_MODEL=mistral:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REVIEWER_MODEL=reviewer-model

# Application
SECRET_KEY=changeme_local_jwt_secret_32chars
ENVIRONMENT=development
LOG_LEVEL=INFO

# Admin auth (single-account login for the UI)
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=Admin1234!
