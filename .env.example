# PostgreSQL
POSTGRES_PASSWORD=changeme_local

# Redis
REDIS_PASSWORD=changeme_local

# ChromaDB
CHROMA_TOKEN=changeme_local

# Neo4j
NEO4J_PASSWORD=changeme_local

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme_local

# LangFuse (self-hosted)
LANGFUSE_SECRET=changeme_local_32chars_xxxxxxxx
